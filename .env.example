# SkyBrief Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# ═══════════════════════════════════════════════════════════════════════════
# Fuel Price API Configuration
# ═══════════════════════════════════════════════════════════════════════════
EXPO_PUBLIC_FUEL_API_KEY=your_api_key_here
EXPO_PUBLIC_FUEL_API_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════
# Firebase Configuration
# ═══════════════════════════════════════════════════════════════════════════
# CRITICAL: Keep these secret! Never commit to git!
# Get these values from Firebase Console > Project Settings

# Google OAuth Web Client ID
# Found in: Firebase Console > Authentication > Sign-in method > Google > Web SDK configuration
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Firebase Project ID
# Found in: Firebase Console > Project Settings > General > Project ID
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id

# ═══════════════════════════════════════════════════════════════════════════
# FAA NOTAM API (server-side only)
# ═══════════════════════════════════════════════════════════════════════════
# NOTAM credentials are now stored in Firebase Cloud Function secrets.
# Set via: firebase functions:secrets:set FAA_NOTAM_CLIENT_ID
#          firebase functions:secrets:set FAA_NOTAM_CLIENT_SECRET
# Register for free credentials at https://api.faa.gov/s/

# ═══════════════════════════════════════════════════════════════════════════
# RevenueCat (In-App Purchases) — Phase 2
# ═══════════════════════════════════════════════════════════════════════════
# RevenueCat iOS API key for subscription management
# Get from RevenueCat Dashboard > Project > API Keys
EXPO_PUBLIC_REVENUECAT_IOS_KEY=your_revenuecat_ios_api_key_here

# ═══════════════════════════════════════════════════════════════════════════
# Security Notes
# ═══════════════════════════════════════════════════════════════════════════
# 1. Never commit .env to version control
# 2. Never share these credentials publicly
# 3. Use different credentials for development/production
# 4. Rotate credentials regularly
# 5. Enable Firebase security rules to prevent unauthorized access
